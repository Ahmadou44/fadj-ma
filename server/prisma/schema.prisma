generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  name      String
  role      String   @default("PATIENT") // PATIENT, PHARMACY, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacy  Pharmacy?
  orders    Order[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Pharmacy {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  name        String
  address     String   @default("Dakar")
  latitude    Float    @default(14.7167)
  longitude   Float    @default(-17.4677)
  license     String?
  isVerified  Boolean  @default(false)
  
  stocks      Stock[]
  sales       Order[]
}

model Drug {
  id          String   @id @default(uuid())
  name        String
  dosage      String?
  form        String?
  class       String?
  description String?
  
  stocks      Stock[]
  orderItems  OrderItem[]
}

model Stock {
  id          String   @id @default(uuid())
  pharmacyId  String
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id])
  drugId      String
  drug        Drug     @relation(fields: [drugId], references: [id])
  quantity    Int      @default(0)
  price       Float    @default(0.0)
  
  @@unique([pharmacyId, drugId])
}

model Order {
  id          String   @id @default(uuid())
  patientId   String
  patient     User     @relation(fields: [patientId], references: [id])
  pharmacyId  String
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id])
  
  status          String   @default("PENDING") // PENDING, CONFIRMED, REJECTED, COMPLETED
  paymentStatus   String   @default("UNPAID")   // UNPAID, PAID, REFUNDED
  paymentMethod   String?                       // ORANGE_MONEY, FREE_MONEY, CASH
  totalPrice      Float    @default(0.0)
  prescriptionUrl String?
  
  items       OrderItem[]
  transactions Transaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Float
  method    String   // ORANGE_MONEY, FREE_MONEY
  status    String   @default("PENDING") // PENDING, SUCCESS, FAILED
  reference String?  // External provider reference
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  content     String
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  drugId    String
  drug      Drug     @relation(fields: [drugId], references: [id])
  quantity  Int
  price     Float
}
